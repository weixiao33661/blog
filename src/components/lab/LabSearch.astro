---
import { Icon } from "astro-icon/components";
---

<div id="lab-search-modal" class="lab-search-modal" role="dialog" aria-modal="true" aria-label="站内搜索" aria-hidden="true">
	<button class="lab-search-backdrop" type="button" data-lab-search-close aria-label="关闭搜索"></button>
	<div class="lab-search-card">
		<header class="lab-search-head">
			<div class="flex items-center gap-2">
				<span class="lab-search-icon">
					<Icon name="material-symbols:search-rounded" />
				</span>
				<span class="font-bold">搜索</span>
			</div>
			<div class="flex items-center gap-2">
				<span class="hidden items-center gap-1 text-xs text-[var(--lab-muted)] sm:flex">
					<kbd>Ctrl</kbd><kbd>K</kbd>
				</span>
				<button class="lab-search-close" type="button" data-lab-search-close aria-label="关闭搜索">
					<Icon name="material-symbols:close-rounded" />
				</button>
			</div>
		</header>
		<div class="lab-search-input-wrap">
			<Icon name="material-symbols:search-rounded" class="text-[1.25rem] text-[var(--lab-muted)]" />
			<input id="lab-search-input" type="search" placeholder="输入关键词搜索文章" autocomplete="off" />
		</div>
		<div id="lab-search-state" class="lab-search-state">
			输入关键词，查找 Android、Reverse、WriteUp 等记录。
		</div>
		<div id="lab-search-results" class="lab-search-results"></div>
		<footer class="lab-search-footer">
			<span>Pagefind</span>
			<span>Esc 关闭</span>
		</footer>
	</div>
</div>

<style>
	.lab-search-modal {
		align-items: flex-start;
		display: flex;
		inset: 0;
		justify-content: center;
		opacity: 0;
		padding: 5.5rem 1rem 1rem;
		pointer-events: none;
		position: fixed;
		transition: opacity 0.18s ease;
		z-index: 80;
	}
	.lab-search-modal.is-open {
		opacity: 1;
		pointer-events: auto;
	}
	.lab-search-backdrop {
		background: rgba(2, 6, 23, 0.56);
		border: 0;
		inset: 0;
		position: absolute;
	}
	.lab-search-card {
		background: color-mix(in srgb, var(--lab-card) 92%, var(--lab-bg));
		border: 1px solid var(--lab-border);
		border-radius: 1rem;
		box-shadow: 0 28px 90px rgba(2, 6, 23, 0.34);
		color: var(--lab-fg);
		max-height: min(42rem, calc(100vh - 7rem));
		max-width: 42rem;
		overflow: hidden;
		position: relative;
		width: 100%;
	}
	.lab-search-head,
	.lab-search-footer {
		align-items: center;
		display: flex;
		justify-content: space-between;
	}
	.lab-search-head {
		border-bottom: 1px solid var(--lab-border);
		padding: 0.85rem 1rem;
	}
	.lab-search-footer {
		border-top: 1px solid var(--lab-border);
		color: var(--lab-muted);
		font-family: "JetBrains Mono Variable", ui-monospace, monospace;
		font-size: 0.72rem;
		padding: 0.65rem 1rem;
		text-transform: uppercase;
	}
	.lab-search-icon,
	.lab-search-close {
		align-items: center;
		border: 1px solid var(--lab-border);
		border-radius: 0.65rem;
		display: inline-flex;
		height: 2rem;
		justify-content: center;
		width: 2rem;
	}
	.lab-search-icon {
		background: color-mix(in srgb, var(--lab-accent) 12%, transparent);
		color: var(--lab-accent);
	}
	.lab-search-close {
		color: var(--lab-muted);
		transition: color 0.2s, border-color 0.2s, background 0.2s;
	}
	.lab-search-close:hover {
		background: color-mix(in srgb, var(--lab-accent) 10%, transparent);
		border-color: color-mix(in srgb, var(--lab-accent) 36%, transparent);
		color: var(--lab-accent);
	}
	kbd {
		border: 1px solid var(--lab-border);
		border-radius: 0.42rem;
		padding: 0.08rem 0.38rem;
	}
	.lab-search-input-wrap {
		align-items: center;
		border-bottom: 1px solid var(--lab-border);
		display: flex;
		gap: 0.6rem;
		padding: 0.9rem 1rem;
	}
	.lab-search-input-wrap input {
		background: transparent;
		color: var(--lab-fg);
		flex: 1;
		font-size: 1rem;
		outline: none;
	}
	.lab-search-input-wrap input::placeholder {
		color: var(--lab-muted);
	}
	.lab-search-state {
		color: var(--lab-muted);
		font-size: 0.9rem;
		padding: 1.5rem 1rem;
		text-align: center;
	}
	.lab-search-results {
		display: grid;
		gap: 0.35rem;
		max-height: calc(min(42rem, calc(100vh - 7rem)) - 10.5rem);
		overflow-y: auto;
		padding: 0.55rem;
	}
	.lab-search-result {
		border: 1px solid transparent;
		border-radius: 0.85rem;
		color: var(--lab-fg);
		display: block;
		padding: 0.75rem 0.85rem;
		text-decoration: none;
		transition: background 0.2s, border-color 0.2s, transform 0.2s;
	}
	.lab-search-result:hover {
		background: color-mix(in srgb, var(--lab-accent) 8%, transparent);
		border-color: color-mix(in srgb, var(--lab-accent) 24%, transparent);
		transform: translateY(-1px);
	}
	.lab-search-title {
		font-weight: 750;
	}
	.lab-search-excerpt {
		color: var(--lab-muted);
		font-size: 0.86rem;
		line-height: 1.55;
		margin-top: 0.28rem;
	}
	.lab-search-excerpt mark {
		background: color-mix(in srgb, var(--lab-accent) 18%, transparent);
		border-radius: 0.25rem;
		color: var(--lab-accent);
		padding-inline: 0.12rem;
	}
</style>

<script>
	type PagefindResult = {
		url: string;
		meta?: {
			title?: string;
		};
		excerpt?: string;
	};

	type PagefindSearchResult = {
		results: Array<{
			data: () => Promise<PagefindResult>;
		}>;
	};

	const fakeResults: PagefindResult[] = [
		{
			url: "/archive/",
			meta: { title: "开发模式搜索预览" },
			excerpt: "开发服务下 Pagefind 索引不可用，构建预览后会使用真实搜索。",
		},
	];

	let pagefindReady = false;
	let pagefindLoading: Promise<void> | null = null;

	async function ensurePagefind() {
		if (import.meta.env.DEV) return;
		if (pagefindReady) return;
		if (!pagefindLoading) {
			pagefindLoading = new Function("path", "return import(path)")("/pagefind/pagefind.js")
				.then((mod: unknown) => {
					(window as any).pagefind = mod;
					pagefindReady = typeof (mod as { search?: unknown }).search === "function";
				})
				.catch((error: unknown) => {
					console.error("Failed to load Pagefind:", error);
				});
		}
		await pagefindLoading;
	}

	function setSearchOpen(open: boolean) {
		const modal = document.getElementById("lab-search-modal");
		const input = document.getElementById("lab-search-input") as HTMLInputElement | null;
		if (!modal) return;

		modal.classList.toggle("is-open", open);
		modal.setAttribute("aria-hidden", open ? "false" : "true");
		document.documentElement.classList.toggle("lab-search-lock", open);
		if (open) {
			void ensurePagefind();
			setTimeout(() => input?.focus(), 40);
		}
	}

	function renderSearchResults(results: PagefindResult[], keyword: string) {
		const state = document.getElementById("lab-search-state");
		const output = document.getElementById("lab-search-results");
		if (!state || !output) return;

		output.innerHTML = "";
		if (!keyword) {
			state.textContent = "输入关键词，查找 Android、Reverse、WriteUp 等记录。";
			state.hidden = false;
			return;
		}

		if (results.length === 0) {
			state.textContent = "没有找到匹配内容。";
			state.hidden = false;
			return;
		}

		state.hidden = true;
		for (const item of results) {
			const link = document.createElement("a");
			link.className = "lab-search-result";
			link.href = item.url;
			link.innerHTML = `
				<div class="lab-search-title">${item.meta?.title || item.url}</div>
				<div class="lab-search-excerpt">${item.excerpt || ""}</div>
			`;
			output.appendChild(link);
		}
	}

	let searchTimer = 0;
	async function runSearch(keyword: string) {
		const trimmed = keyword.trim();
		if (!trimmed) {
			renderSearchResults([], "");
			return;
		}

		if (import.meta.env.DEV) {
			renderSearchResults(fakeResults, trimmed);
			return;
		}

		await ensurePagefind();
		const pagefind = (window as any).pagefind;
		if (!pagefind?.search) {
			renderSearchResults([], trimmed);
			return;
		}

		const search = (await pagefind.search(trimmed)) as PagefindSearchResult;
		const results = await Promise.all(search.results.slice(0, 8).map((item) => item.data()));
		renderSearchResults(results, trimmed);
	}

	function initLabSearch() {
		document.querySelectorAll<HTMLElement>("[data-lab-search-open]").forEach((trigger) => {
			if (trigger.dataset.searchInited === "true") return;
			trigger.dataset.searchInited = "true";
			trigger.addEventListener("click", (event) => {
				event.preventDefault();
				setSearchOpen(true);
			});
		});

		document.querySelectorAll<HTMLElement>("[data-lab-search-close]").forEach((trigger) => {
			if (trigger.dataset.searchInited === "true") return;
			trigger.dataset.searchInited = "true";
			trigger.addEventListener("click", () => setSearchOpen(false));
		});

		const input = document.getElementById("lab-search-input") as HTMLInputElement | null;
		if (input && input.dataset.searchInited !== "true") {
			input.dataset.searchInited = "true";
			input.addEventListener("input", () => {
				window.clearTimeout(searchTimer);
				searchTimer = window.setTimeout(() => {
					void runSearch(input.value);
				}, 120);
			});
		}
	}

	initLabSearch();
	document.addEventListener("keydown", (event) => {
		const isK = event.key.toLowerCase() === "k";
		if ((event.ctrlKey || event.metaKey) && isK) {
			event.preventDefault();
			setSearchOpen(true);
		}
		if (event.key === "Escape") {
			setSearchOpen(false);
		}
	});
	document.addEventListener("swup:enable", () => {
		(window as any).swup?.hooks?.on?.("page:view", initLabSearch);
	});
</script>
