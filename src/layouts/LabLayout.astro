---
import Layout from "./Layout.astro";
import LabFooter from "../components/lab/LabFooter.astro";
import LabHeader from "../components/lab/LabHeader.astro";
import LabSearch from "../components/lab/LabSearch.astro";

interface Props {
	title?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
}

const { title, description, lang, setOGTypeArticle } = Astro.props;
---

<Layout title={title} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle} bodyClass="lab-body">
	<slot slot="head" name="head"></slot>
	<LabHeader />
	<main id="swup-container" class="lab-page min-h-[calc(100vh-10rem)]">
		<slot />
	</main>
	<div id="toc" class="hidden"></div>
	<LabFooter />
	<LabSearch />
</Layout>

<style is:global>
	:root {
		--lab-bg: #f8fafc;
		--lab-card: rgba(255, 255, 255, 0.78);
		--lab-fg: #0f172a;
		--lab-muted: rgba(51, 65, 85, 0.68);
		--lab-border: rgba(15, 23, 42, 0.12);
		--lab-accent: #0d9488;
		--lab-shell: 62rem;
	}
	:root.dark {
		--lab-bg: #020617;
		--lab-card: rgba(15, 23, 42, 0.58);
		--lab-fg: #e5eefb;
		--lab-muted: rgba(203, 213, 225, 0.62);
		--lab-border: rgba(148, 163, 184, 0.18);
		--lab-accent: #2dd4bf;
	}
	.lab-shell {
		margin-inline: auto;
		max-width: var(--lab-shell);
		padding-inline: 1rem;
		width: 100%;
	}
	.lab-page {
		color: var(--lab-fg);
		position: relative;
	}
	.lab-search-lock {
		overflow: hidden;
	}
	.lab-page::before {
		background:
			linear-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(148, 163, 184, 0.08) 1px, transparent 1px);
		background-size: 44px 44px;
		content: "";
		inset: 0;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.58), transparent 60%);
		pointer-events: none;
		position: absolute;
		z-index: -1;
	}
	body.lab-body #security-bg {
		background:
			radial-gradient(circle at 18% 10%, color-mix(in srgb, var(--lab-accent) 22%, transparent), transparent 28%),
			radial-gradient(circle at 78% 18%, rgba(59, 130, 246, 0.13), transparent 34%),
			linear-gradient(135deg, var(--lab-bg), color-mix(in srgb, var(--lab-bg) 86%, #0f172a));
	}
	body.lab-body #security-bg-grid {
		opacity: 0.72;
	}
	body.lab-body #security-bg-overlay {
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--lab-bg) 12%, transparent) 0%, color-mix(in srgb, var(--lab-bg) 82%, transparent) 74%, var(--lab-bg) 100%);
	}
	.lab-hero-title {
		background: linear-gradient(
			135deg,
			var(--lab-accent) 0%,
			color-mix(in oklab, var(--lab-accent) 45%, var(--lab-fg)) 18%,
			var(--lab-fg) 34%,
			var(--lab-fg) 66%,
			color-mix(in oklab, var(--lab-accent) 45%, var(--lab-fg)) 82%,
			var(--lab-accent) 100%
		);
		background-clip: text;
		background-size: 250% auto;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		animation: lab-shimmer 6s ease-in-out infinite;
	}
	@keyframes lab-shimmer {
		0%, 100% {
			background-position: 0% center;
		}
		50% {
			background-position: 100% center;
		}
	}
</style>

<script>
	function initLabEffects() {
		document.querySelectorAll<HTMLElement>(".card-glow").forEach((card) => {
			if (card.dataset.glowInited === "true") return;
			card.dataset.glowInited = "true";
			card.addEventListener("mousemove", (event) => {
				const rect = card.getBoundingClientRect();
				card.style.setProperty("--mouse-x", `${event.clientX - rect.left}px`);
				card.style.setProperty("--mouse-y", `${event.clientY - rect.top}px`);
			});
		});
	}

	initLabEffects();
	document.addEventListener("swup:enable", () => {
		(window as any).swup?.hooks?.on?.("page:view", initLabEffects);
	});
</script>
